# Force all requests to go through Node.js application
# This is critical for cPanel Node.js apps

# Enable rewrite engine
RewriteEngine On

# Don't rewrite files that actually exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Proxy all requests to Node.js app
# Replace PORT with your actual Node.js port (usually shown in cPanel)
RewriteRule ^(.*)$ http://127.0.0.1:8000/$1 [P,L]

# Enable CORS headers at Apache level as backup
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    Header always set Access-Control-Allow-Credentials "true"
</IfModule>

# Handle preflight OPTIONS requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]